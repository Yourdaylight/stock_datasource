{
  "name": "clickhouse_query",
  "description": "Enhanced ClickHouse query service with table structure and stock filtering tools",
  "version": "1.1.0",
  "type": "query",
  "methods": [
    {
      "name": "get_table_schema",
      "description": "Get table structure and field information",
      "parameters": {
        "table": {
          "type": "string",
          "required": true,
          "description": "Table name to inspect"
        }
      },
      "returns": {
        "type": "object",
        "description": "Table schema with field names, types, and descriptions"
      }
    },
    {
      "name": "list_tables",
      "description": "List all available tables in the database",
      "parameters": {},
      "returns": {
        "type": "array",
        "description": "List of table names"
      }
    },
    {
      "name": "filter_daily_data",
      "description": "Filter ods_daily table with flexible conditions for stock price data",
      "parameters": {
        "trade_date": {
          "type": "string",
          "required": false,
          "description": "Trade date in YYYYMMDD format (e.g., '20241201')"
        },
        "ts_codes": {
          "type": "array",
          "required": false,
          "description": "List of stock codes (e.g., ['000001.SZ', '000002.SZ'])"
        },
        "pct_chg_min": {
          "type": "number",
          "required": false,
          "description": "Minimum percentage change"
        },
        "pct_chg_max": {
          "type": "number",
          "required": false,
          "description": "Maximum percentage change"
        },
        "close_min": {
          "type": "number",
          "required": false,
          "description": "Minimum closing price"
        },
        "close_max": {
          "type": "number",
          "required": false,
          "description": "Maximum closing price"
        },
        "vol_min": {
          "type": "number",
          "required": false,
          "description": "Minimum volume"
        },
        "amount_min": {
          "type": "number",
          "required": false,
          "description": "Minimum amount"
        },
        "limit": {
          "type": "integer",
          "required": false,
          "default": 100,
          "description": "Maximum number of rows to return"
        },
        "order_by": {
          "type": "string",
          "required": false,
          "default": "pct_chg DESC",
          "description": "Order by clause (e.g., 'pct_chg DESC', 'close ASC')"
        }
      },
      "returns": {
        "type": "array",
        "description": "Filtered daily stock data"
      }
    },
    {
      "name": "filter_daily_basic",
      "description": "Filter ods_daily_basic table with flexible conditions for stock fundamental data",
      "parameters": {
        "trade_date": {
          "type": "string",
          "required": false,
          "description": "Trade date in YYYYMMDD format (e.g., '20241201')"
        },
        "ts_codes": {
          "type": "array",
          "required": false,
          "description": "List of stock codes (e.g., ['000001.SZ', '000002.SZ'])"
        },
        "pe_min": {
          "type": "number",
          "required": false,
          "description": "Minimum P/E ratio"
        },
        "pe_max": {
          "type": "number",
          "required": false,
          "description": "Maximum P/E ratio"
        },
        "pb_min": {
          "type": "number",
          "required": false,
          "description": "Minimum P/B ratio"
        },
        "pb_max": {
          "type": "number",
          "required": false,
          "description": "Maximum P/B ratio"
        },
        "dv_ratio_min": {
          "type": "number",
          "required": false,
          "description": "Minimum dividend ratio (%)"
        },
        "dv_ratio_max": {
          "type": "number",
          "required": false,
          "description": "Maximum dividend ratio (%)"
        },
        "total_mv_min": {
          "type": "number",
          "required": false,
          "description": "Minimum total market value (in ten thousand)"
        },
        "total_mv_max": {
          "type": "number",
          "required": false,
          "description": "Maximum total market value (in ten thousand)"
        },
        "circ_mv_min": {
          "type": "number",
          "required": false,
          "description": "Minimum circulating market value (in ten thousand)"
        },
        "circ_mv_max": {
          "type": "number",
          "required": false,
          "description": "Maximum circulating market value (in ten thousand)"
        },
        "limit": {
          "type": "integer",
          "required": false,
          "default": 100,
          "description": "Maximum number of rows to return"
        },
        "order_by": {
          "type": "string",
          "required": false,
          "default": "dv_ratio DESC",
          "description": "Order by clause (e.g., 'pe ASC', 'total_mv DESC')"
        }
      },
      "returns": {
        "type": "array",
        "description": "Filtered daily basic stock data"
      }
    },
    {
      "name": "execute_raw_query",
      "description": "Execute raw SQL query",
      "parameters": {
        "sql": {
          "type": "string",
          "required": true,
          "description": "Raw SQL query to execute"
        }
      },
      "returns": {
        "type": "array",
        "description": "Query results"
      }
    }
  ]
}