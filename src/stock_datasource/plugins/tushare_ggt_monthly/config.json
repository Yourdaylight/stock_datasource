{
  "plugin_name": "tushare_ggt_monthly",
  "display_name": "港股通每月成交统计",
  "description": "获取港股通每月成交信息，数据从2014年开始",
  "api_name": "ggt_monthly",
  "category": "HK_STOCK",
  "data_role": "PRIMARY",
  "update_frequency": "monthly",
  "min_points": 5000,
  "max_rows_per_call": 1000,
  "dependencies": [],
  "schedule": {
    "frequency": "monthly",
    "time": "18:00"
  },
  "enabled": true,
  "parameters_schema": {
    "month": {
      "type": "string",
      "required": false,
      "description": "交易月份（YYYYMM格式，支持逗号分隔多月）"
    },
    "start_month": {
      "type": "string",
      "required": false,
      "description": "开始月份（YYYYMM格式）"
    },
    "end_month": {
      "type": "string",
      "required": false,
      "description": "结束月份（YYYYMM格式）"
    }
  }
}
