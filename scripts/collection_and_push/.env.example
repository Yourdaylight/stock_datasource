# =============================================================================
# CSV 实时数据流水线 — 环境配置模板
# 文件位置: scripts/collection_and_push/.env
#
# 复制此文件为 .env 并填入实际值:
#   cp .env.example .env
#   vim .env
# =============================================================================

# ---- TuShare 采集配置（仅代理服务器需要）----
TUSHARE_TOKEN=your_tushare_token_here
# TUSHARE_API_URL=https://api.tushare.pro     # 可选，覆盖默认 API 地址
# HTTP_PROXY=http://127.0.0.1:7890            # 可选，代理

# ---- 推送鉴权 Token（代理和所有订阅节点需一致）----
RT_KLINE_CLOUD_PUSH_TOKEN=your_push_token_here

# ---- 推送 URL（仅代理服务器的 csv_pipeline 使用）----
# RT_KLINE_CLOUD_PUSH_URL=http://your-push-node:9100/api/v1/rt-kline/push

# ---- 节点地址（start_proxy.sh 使用）----
# 每个节点的推送 API 地址，格式: http://IP:PORT/api/v1/rt-kline/push
NODE1_URL=http://your-node1-ip:9100/api/v1/rt-kline/push
NODE2_URL=http://your-node2-ip:9100/api/v1/rt-kline/push
NODE3_URL=http://your-node3-ip:9100/api/v1/rt-kline/push

# ---- 订阅鉴权（可选，订阅节点用）----
# RT_STOCK_POLICY_TOKEN=your_policy_token
# RT_STOCK_JWT_PUBLIC_KEY_PATH=/path/to/public.pem

# ---- 流水线调优（可选，start_proxy.sh 使用）----
# 默认让推送与采集同频，并将每个 CSV 限制在最近 10 万行
# COLLECT_INTERVAL=3.0
# PUSH_INTERVAL=3.0
# CSV_MAX_KEEP_ROWS=100000
# PUSH_BATCH_SIZE=3000
