{
  "name": "stock-rt-subscribe",
  "description": "实时股票数据订阅服务 - 通过WebSocket长连接接收A股、港股、ETF的实时行情数据",
  "version": "1.0.0",
  "author": "stock_datasource",
  "category": "finance",
  "tags": ["stock", "realtime", "websocket", "subscription"],
  
  "entry_point": "ai_agent_integration.py",
  "requirements": ["requests", "websockets"],
  
  "parameters": {
    "node_url": {
      "type": "string",
      "description": "Receiver节点HTTP地址（必填）",
      "required": true,
      "env_var": "STOCK_RT_NODE_URL"
    },
    "token": {
      "type": "string", 
      "description": "鉴权Token（可选）",
      "required": false,
      "env_var": "STOCK_RT_TOKEN"
    },
    "symbols": {
      "type": "array",
      "description": "要订阅的股票代码列表（如['00700.HK', '600519.SH']）",
      "required": true
    },
    "ws_port": {
      "type": "integer",
      "description": "WebSocket服务端口（默认8765）",
      "default": 8765,
      "env_var": "STOCK_WS_PORT"
    },
    "poll_interval": {
      "type": "number",
      "description": "数据轮询间隔秒数（默认3.0）",
      "default": 3.0
    },
    "alert_threshold": {
      "type": "number", 
      "description": "涨跌幅告警阈值（如2.0表示±2%）",
      "default": 0.0
    }
  },
  
  "actions": {
    "install": {
      "description": "安装 skill：检查依赖、初始化 .env 配置、验证节点和 MCP 连通性，一键完成安装",
      "method": "install",
      "usage": "agent = StockDataAgent(); agent.install()",
      "steps": [
        "检查并自动安装 Python 依赖（requests、websockets）",
        "若 .env 不存在则交互式引导配置节点地址、Token、MCP 地址",
        "验证 Receiver 节点 /health 连通性",
        "验证 MCP 服务可达性",
        "打印安装成功摘要和快速开始示例"
      ]
    },
    "start_service": {
      "description": "启动WebSocket订阅服务",
      "command": "python3 subscribe_client.py --node-url {node_url} --symbols {symbols} --ws-port {ws_port}",
      "async": true
    },
    "connect_client": {
      "description": "连接WebSocket服务接收实时数据",
      "script": "ai_agent_demo.py"
    },
    "subscribe_symbols": {
      "description": "动态添加订阅股票",
      "message_format": {
        "action": "subscribe",
        "symbols": ["symbol1", "symbol2"]
      }
    },
    "unsubscribe_symbols": {
      "description": "动态取消订阅股票", 
      "message_format": {
        "action": "unsubscribe", 
        "symbols": ["symbol1", "symbol2"]
      }
    },
    "get_snapshot": {
      "description": "获取当前所有最新行情快照",
      "message_format": {
        "action": "snapshot"
      }
    }
  },
  
  "output_formats": {
    "tick_data": {
      "type": "object",
      "fields": {
        "ts_code": "股票代码",
        "name": "股票名称", 
        "market": "市场类型",
        "close": "最新价",
        "pct_chg": "涨跌幅",
        "vol": "成交量",
        "amount": "成交额",
        "timestamp": "时间戳"
      }
    }
  },
  
  "examples": [
    {
      "description": "订阅港股腾讯和A股茅台",
      "command": "python3 subscribe_client.py --node-url http://139.155.0.115:9100 --symbols 00700.HK 600519.SH"
    },
    {
      "description": "带告警的订阅服务",
      "command": "python3 subscribe_client.py --node-url http://139.155.0.115:9100 --symbols 00700.HK 09988.HK --alert-pct 2.0"
    }
  ],
  
  "integration_guide": {
    "ai_agent_usage": "AI agent可以通过启动WebSocket服务作为数据源，然后连接本地WebSocket端口接收实时数据流。支持动态订阅管理和数据过滤。",
    "authentication": "需要设置STOCK_RT_NODE_URL环境变量指向Receiver节点，如有鉴权需求设置STOCK_RT_TOKEN环境变量。",
    "data_flow": "Receiver节点 → HTTP API（批量拉取）→ subscribe_client.py（WebSocket服务）→ ws://localhost:8765 → AI agent客户端"
  }
}